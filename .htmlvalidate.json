{
  "$schema": "https://html-validate.org/schemas/config.json",
  "extends": [
    "html-validate:recommended",
    "html-validate:document"
  ],
  "rules": {
    "void-style": ["error", { "style": "omit" }],
    "attribute-boolean-style": ["error", { "style": "omit" }],
    "attribute-allowed-values": "error",
    "attribute-misuse": "error",
    "no-trailing-whitespace": "off",
    "no-inline-style": "off",
    "no-implicit-button-type": "error",
    "no-redundant-role": "error",
    "no-redundant-aria-label": "error",
    "wcag/h30": "error",
    "wcag/h32": "error",
    "wcag/h36": "error",
    "wcag/h37": "error",
    "wcag/h63": "error",
    "wcag/h67": "error",
    "wcag/h71": "error",
    "input-missing-label": "error",
    "no-missing-references": "error",
    "no-dup-id": "error",
    "no-dup-class": "warn",
    "no-deprecated-attr": "error",
    "element-required-attributes": "error",
    "element-required-content": "error",
    "element-permitted-content": "error",
    "element-permitted-occurrences": "off",
    "element-permitted-parent": "error",
    "heading-level": "error",
    "long-title": ["warn", { "maxlength": 70 }],
    "meta-refresh": "error",
    "no-autoplay": "error",
    "require-sri": "off",
    "no-raw-characters": ["error", { "relaxed": true }],
    "doctype-style": ["error", { "style": "lowercase" }],
    "no-multiple-main": "error",
    "no-conditional-comment": "error",
    "tel-non-breaking": "warn",
    "no-unknown-elements": "error",
    "valid-id": "error",
    "prefer-button": "off",
    "prefer-native-element": "warn",
    "require-csp-nonce": "off",
    "form-dup-name": ["error", { "allowArrayBrackets": true, "shared": ["radio", "checkbox", "submit", "button", "reset"] }]
  },
  "elements": [
    "html5"
  ]
}
